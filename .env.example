# Supabase (frontend - expostas via Vite)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Supabase (backend / scripts)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Redirecionamento do e-mail de confirmação (opcional; default: origem atual no navegador).
# Use a origem do app em produção se o cadastro for testado fora desse host (ex.: só domínio).
# No Vercel: Production + nome exato VITE_AUTH_REDIRECT_BASE; valor embutido no `vite build`.
# Pode omitir o protocolo (ex.: neworca.vercel.app → https://…).
# VITE_AUTH_REDIRECT_BASE=https://neworca.vercel.app

# Servidor PDF
PORT=3333
HOST=0.0.0.0

# Template "Confirm sign up" no Supabase Auth (script: npm run supabase:auth-templates)
# Requer SUPABASE_URL e SUPABASE_ACCESS_TOKEN no ambiente ao rodar o script.
# O script usa o mesmo carregamento de `.env*` que o Vite (`loadEnv`): `.env`, `.env.local`, `.env.<modo>`, `.env.<modo>.local`.
# Modo (igual ao `vite build` por defeito): AUTH_TEMPLATES_VITE_MODE=production — use `development` para alinhar ao `vite dev`.
# Variáveis já definidas no shell/CI não são sobrescritas pelos ficheiros.
# Se CONFIRMATION_SUBJECT e CONFIRMATION_CONTENT forem omitidos, o script usa o assunto e o HTML padrão embutidos (recomendado).
# CONFIRMATION_SUBJECT=uma única linha (assunto do e-mail).
# CONFIRMATION_CONTENT=HTML do corpo — deve incluir literalmente {{ .Data.login_code }} e {{ .ConfirmationURL }} (validação no script).
# Override longo em .env: uma única linha (minificado) ou export no CI/shell onde multilinha é aceite.
# VITE_AUTH_REDIRECT_BASE: mesma chave e mesma resolução que no build da app — defina em `.env.production` (ou CI) para coincidir com produção.

# SMTP (usado nos scripts de configuração)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
SMTP_FROM_ADDRESS=

# Testes de integração
TEST_EMAIL=
TEST_PASSWORD=
TEST_EMAIL_REDIRECT_TO=http://localhost:5173/auth/confirm-callback
SKIP_SIGNUP_TEST=false

# Supabase (frontend - expostas via Vite)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Supabase (backend / scripts)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Redirecionamento de autenticação (opcional, default: window.location.origin)
VITE_AUTH_REDIRECT_BASE=http://localhost:5173

# Servidor PDF
PORT=3333
HOST=0.0.0.0

# SMTP (usado nos scripts de configuração)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
SMTP_FROM_ADDRESS=

# Testes de integração
TEST_EMAIL=
TEST_PASSWORD=
TEST_EMAIL_REDIRECT_TO=http://localhost:5173/configuracoes
SKIP_SIGNUP_TEST=false

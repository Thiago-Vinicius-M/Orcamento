generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Loja {
  id        Int      @id @default(autoincrement())
  nome      String
  cnpj      String
  endereco  String   @default("")
  telefone  String   @default("")
  email     String   @default("")
  logo      String   @default("")
  updatedAt DateTime @updatedAt
}

model Cliente {
  id          Int         @id @default(autoincrement())
  nome        String
  cpfCnpj     String
  telefone    String
  email       String      @default("")
  logradouro  String      @default("")
  numero      String      @default("")
  complemento String      @default("")
  bairro      String      @default("")
  cidade      String      @default("")
  estado      String      @default("")
  cep         String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orcamentos  Orcamento[]
}

model Produto {
  id             Int             @id @default(autoincrement())
  nome           String
  descricao      String          @default("")
  preco          Float
  codigoSku      String
  categoria      String
  imagem         String          @default("")
  ativo          Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itensOrcamento ItemOrcamento[]
}

model Orcamento {
  id                 Int                 @id @default(autoincrement())
  numero             Int                 @unique
  clienteId          Int
  cliente            Cliente             @relation(fields: [clienteId], references: [id])
  dataEmissao        DateTime
  dataValidade       DateTime
  subtotal           Float
  descontoValor      Float               @default(0)
  descontoPercentual Float               @default(0)
  total              Float
  status             String              @default("vigente")
  observacoes        String              @default("")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  itens              ItemOrcamento[]
  condicoes          CondicaoPagamento[]
}

model ItemOrcamento {
  id            Int       @id @default(autoincrement())
  orcamentoId   Int
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  produtoId     Int
  produto       Produto   @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Float
  subtotal      Float
}

model CondicaoPagamento {
  id                 Int       @id @default(autoincrement())
  orcamentoId        Int
  orcamento          Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  formaPagamento     String
  parcelas           Int
  valorParcela       Float
  valorTotal         Float
  descontoPercentual Float     @default(0)
  observacoes        String    @default("")
}

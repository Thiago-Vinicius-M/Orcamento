########################################
# Variáveis de ambiente da API (Express)
########################################

# URL pública do frontend utilizada para montar links enviados por e-mail.
# - Em desenvolvimento local: http://localhost:5173
# - Em produção na Vercel: URL do deploy (ex.: https://seu-projeto.vercel.app)
APP_URL=http://localhost:5173

########################################
# Autenticação (JWT)
########################################

# Chave secreta usada para assinar e validar tokens JWT.
# Gere um valor forte e mantenha-o em segredo.
JWT_SECRET=sua_chave_secreta_segura_aqui

########################################
# Supabase (banco de dados)
########################################

# URL do projeto Supabase (Project Settings → API → Project URL).
SUPABASE_URL=https://seu-projeto.supabase.co

# Service Role Key (Project Settings → API → service_role key).
# ATENÇÃO: esta chave é sensível e deve ficar apenas no backend (API / Vercel),
# nunca no frontend.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

########################################
# E-mail (Nodemailer)
########################################

# Remetente padrão dos e-mails de confirmação.
# Exemplo: "Seu Nome <no-reply@suaempresa.com>"
EMAIL_FROM="Orçamento App <no-reply@exemplo.com>"

# Configuração do servidor SMTP usado para envio de e-mails.
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=usuario_smtp
SMTP_PASS=senha_smtp

########################################
# Ambiente
########################################

# Em desenvolvimento local normalmente será "development".
# Na Vercel, a própria plataforma define NODE_ENV=production nos deploys de produção.
NODE_ENV=development

########################################
# Observação sobre Vercel
########################################

# Para rodar na Vercel, cadastre TODAS as variáveis acima
# em Project Settings → Environment Variables, nos ambientes
# "Development", "Preview" e "Production", conforme necessário.
#
# Em produção:
# - APP_URL deve apontar para a URL pública do frontend (por ex. https://seu-projeto.vercel.app)
# - SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY devem ser os valores reais do seu projeto Supabase
# - JWT_SECRET deve ser uma chave forte e única
# - EMAIL_FROM/SMTP_* devem ter os dados reais do seu serviço de e-mail

PORT=3001
NODE_ENV=development

# URL da aplicação frontend (usada no link de confirmação de cadastro por e-mail)
# Em desenvolvimento normalmente é o Vite na porta 5173
APP_URL=http://localhost:5173

# Chave usada para assinar o JWT de autenticação
# Em produção, use uma string longa e aleatória
JWT_SECRET=altere-esta-chave-para-uma-string-bem-segura

# Configuração de SMTP para envio de e-mails de confirmação
# Gmail: use SMTP_HOST=smtp.gmail.com, SMTP_PORT=587 e uma "Senha de app"
# (não use a senha normal da conta). Crie em: Conta Google > Segurança > Senhas de app
# https://support.google.com/accounts/answer/185833
EMAIL_FROM="Seu Nome <seu-email@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-16-caracteres

# Configuração do Supabase
# Valores obtidos em: Project Settings → API no painel do Supabase
# SUPABASE_URL: URL base do projeto (ex.: https://xxxxx.supabase.co)
# SUPABASE_ANON_KEY: chave pública (anon) usada no frontend e, se desejar, no backend
# SUPABASE_SERVICE_ROLE_KEY: chave de serviço, mantenha APENAS no backend
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-super-secreta
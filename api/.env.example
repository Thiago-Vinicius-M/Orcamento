PORT=3001
NODE_ENV=development

# URL da aplicação frontend (usada no link de confirmação de cadastro por e-mail)
# Em desenvolvimento normalmente é o Vite na porta 5173
APP_URL=http://localhost:5173

# Chave usada para assinar o JWT de autenticação
# Em produção, use uma string longa e aleatória
JWT_SECRET=altere-esta-chave-para-uma-string-bem-segura

# Configuração de SMTP para envio de e-mails de confirmação
# Gmail: use SMTP_HOST=smtp.gmail.com, SMTP_PORT=587 e uma "Senha de app"
# (não use a senha normal da conta). Crie em: Conta Google > Segurança > Senhas de app
# https://support.google.com/accounts/answer/185833
EMAIL_FROM="Seu Nome <seu-email@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-16-caracteres

# Configuração do Supabase
# Valores obtidos em: Project Settings → API no painel do Supabase
# SUPABASE_URL: URL base do projeto (ex.: https://xxxxx.supabase.co)
# SUPABASE_ANON_KEY: chave pública (anon) usada no frontend e, se desejar, no backend
# SUPABASE_SERVICE_ROLE_KEY: chave de serviço, mantenha APENAS no backend
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-super-secreta
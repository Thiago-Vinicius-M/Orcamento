{
  "name": "neworca",
  "private": true,
  "version": "0.0.0",
  "description": "Sistema de orçamentos NewOrca - frontend Vite + backend PDF em Node/TypeScript",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:pdf": "tsx watch src/server.ts",
    "build:pdf": "tsc",
    "start:pdf": "node dist/server.js",
    "supabase:deploy:functions": "supabase functions deploy register-gerente create-vendedor login-vendedor resolve-vendedor-email",
    "supabase:auth-templates": "tsx scripts/setup-supabase-auth-templates.ts",
    "test:integration:auth": "tsx scripts/auth-integration-tests.ts",
    "test:e2e:auth-flow": "tsx scripts/e2e-auth-flow.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.99.2",
    "deno": "^2.7.7",
    "fastify": "^5.0.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "supabase": "^2.83.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
